<Page x:Class="RegentHealth.Views.DoctorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Doctor Dashboard">
    <Page.Resources>

        
        <Style x:Key="BackArrow" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="22"/>
            <Setter Property="Foreground"      Value="#444"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Width"           Value="36"/>
            <Setter Property="Height"          Value="36"/>
         
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="Transparent"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>



    <Grid Background="#f0f0f0" Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

            <RowDefinition Height="Auto"/>

        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>

            <ColumnDefinition Width="Auto"/>

            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Button Style="{StaticResource BackArrow}"
                Content="&#x2190;"
                ToolTip="Back"
                Click="Back_Click"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="0,0,0,10"/>


        <Grid Grid.Row="0" Margin="0,0,0,20">

            <TextBlock Grid.Column="1"
                       Text="Doctor Appointments"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

        </Grid>


        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                Padding="15"
                Margin="0,0,0,20"
                BorderBrush="#DDD"
                BorderThickness="1">

            <DockPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <TextBlock Text="Shift Status:"
                               FontWeight="Bold"
                               FontSize="14"
                               VerticalAlignment="Center"/>

                    <TextBlock x:Name="ShiftStatusText"
                               Text="OFFLINE"
                               FontWeight="Bold"
                               Foreground="Red"
                               Margin="10,0"
                               VerticalAlignment="Center"/>

                </StackPanel>

                <Button x:Name="ShiftButton"
                        Content="Start Shift"
                        Width="120"
                        Height="32"
                        Margin="10,0"
                        DockPanel.Dock="Right"/>

            </DockPanel>

        </Border>

        <!-- APPOINTMENTS LIST -->
        <ListBox Grid.Row="2"
                 ItemsSource="{Binding Appointments}"
                 SelectedItem="{Binding SelectedAppointment}">

            <ListBox.ItemTemplate>
                <DataTemplate>

                    <Border BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Margin="5"
                            Background="White">

                        <Border.Style>
                            <Style TargetType="Border">

                                <Setter Property="BorderBrush" Value="#DDD"/>

                                <Style.Triggers>

                                    <DataTrigger Binding="{Binding Status}" Value="Scheduled">
                                        <Setter Property="BorderBrush" Value="Green"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding Status}" Value="Completed">
                                        <Setter Property="BorderBrush" Value="DodgerBlue"/>
                                        <Setter Property="Opacity" Value="0.7"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                        <Setter Property="BorderBrush" Value="IndianRed"/>
                                        <Setter Property="Opacity" Value="0.6"/>
                                    </DataTrigger>

                                    <!-- missed - серый с низкой прозрачностью -->
                                    <DataTrigger Binding="{Binding Status}" Value="Missed">
                                        <Setter Property="BorderBrush" Value="#999"/>
                                        <Setter Property="Opacity" Value="0.5"/>
                                    </DataTrigger>

                                </Style.Triggers>

                            </Style>
                        </Border.Style>

                        <StackPanel>

                            <!-- PATIENT -->
                            <TextBlock FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="DarkSlateGray"
                                       Text="{Binding PatientFullName}"/>

                            <!-- DATE -->
                            <TextBlock FontWeight="SemiBold"
                                       Margin="0,6,0,0"
                                       Text="{Binding AppointmentDate,
                                       StringFormat='{}{0:dd MMM yyyy}'}"/>

                            <!-- TIME -->
                            <TextBlock Text="{Binding AppointmentDate,
                                       StringFormat='{}{0:HH:mm}'}"/>

                            <!-- TYPE -->
                            <TextBlock Margin="0,6,0,0"
                                       Text="{Binding Type,
                                       StringFormat='Type: {0}'}"/>

                            <!-- STATUS -->
                            <TextBlock Text="{Binding Status,
                                       StringFormat='Status: {0}'}"/>

                        </StackPanel>

                    </Border>

                </DataTemplate>
            </ListBox.ItemTemplate>

        </ListBox>

        <!-- COMPLETE BUTTON -->
        <Button Grid.Row="3"
                Content="Complete Appointment"
                Width="200"
                Height="35"
                HorizontalAlignment="Center"
                Margin="0,15,0,0"
                Click="CompleteAppointment_Click"/>

    </Grid>
</Page>