<Page x:Class="RegentHealth.Views.Admin.RotationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Weekly Rotation">

    <Page.Resources>

        <GridLength x:Key="NameColumnWidth">180</GridLength>
        <GridLength x:Key="DayColumnWidth">148</GridLength>

        <Style x:Key="DayHeaderNormal" TargetType="Border">
            <Setter Property="Background"   Value="#555555"/>
            <Setter Property="Padding"      Value="8,8"/>
            <Setter Property="Margin"       Value="1,0"/>
        </Style>

        <Style x:Key="DayHeaderToday" TargetType="Border">
            <Setter Property="Background"   Value="#3a7d44"/>
            <Setter Property="Padding"      Value="8,8"/>
            <Setter Property="Margin"       Value="1,0"/>
        </Style>

        <Style x:Key="DoctorRowGrid" TargetType="Grid">
            <Setter Property="Margin"       Value="0,0,0,1"/>
        </Style>

        <Style x:Key="DoctorNameCell" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding"           Value="10,8"/>
            <Setter Property="Background"        Value="White"/>
        </Style>

        <Style x:Key="DayCell" TargetType="StackPanel">
            <Setter Property="Orientation"         Value="Horizontal"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
            <Setter Property="Background"          Value="White"/>
            <Setter Property="Margin"              Value="1,0"/>
            <Setter Property="Height"              Value="36"/>
        </Style>

        <Style x:Key="WorkingCheckBox" TargetType="CheckBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="8,0,4,0"/>
            <Setter Property="ToolTip"           Value="Working this day"/>
        </Style>

        <Style x:Key="EmergencyCheckBox" TargetType="CheckBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="12,0,8,0"/>
            <Setter Property="ToolTip"           Value="Emergency / On-call"/>
        </Style>

        <Style x:Key="NoDoctorsText" TargetType="TextBlock">
            <Setter Property="FontSize"            Value="14"/>
            <Setter Property="Foreground"          Value="Gray"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin"              Value="0,30,0,0"/>
        </Style>

    </Page.Resources>

    <Grid Background="#f0f0f0" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Weekly Doctor Rotation"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,4"/>
            <TextBlock x:Name="WeekRangeText"
                       FontSize="13"
                       Foreground="#555"/>
        </StackPanel>

        <!-- NAV BUTTONS -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,10">
            <Button Content="&lt; Prev Week"
                    Width="100" Height="28"
                    Margin="0,0,8,0"
                    Click="PrevWeek_Click"/>
            <Button Content="Next Week &gt;"
                    Width="100" Height="28"
                    Click="NextWeek_Click"/>
        </StackPanel>

        <!-- TABLE -->
        <ScrollViewer Grid.Row="2"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Day header row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="148"/>
                        <ColumnDefinition Width="148"/>
                        <ColumnDefinition Width="148"/>
                        <ColumnDefinition Width="148"/>
                        <ColumnDefinition Width="148"/>
                        <ColumnDefinition Width="148"/>
                        <ColumnDefinition Width="148"/>
                    </Grid.ColumnDefinitions>

                    <!-- Corner -->
                    <Border Grid.Column="0" Background="#555555" Padding="10,8" Margin="1,0">
                        <TextBlock Text="Doctor" Foreground="White" FontWeight="Bold" FontSize="13"/>
                    </Border>

                    <!-- Mon -->
                    <Border x:Name="DayHeader0" Grid.Column="1" Style="{StaticResource DayHeaderNormal}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="DayName0" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="DayDate0" Foreground="#CCC" FontSize="11" HorizontalAlignment="Center"/>
                            <TextBlock Text="Work | Emg" Foreground="#AAA" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Tue -->
                    <Border x:Name="DayHeader1" Grid.Column="2" Style="{StaticResource DayHeaderNormal}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="DayName1" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="DayDate1" Foreground="#CCC" FontSize="11" HorizontalAlignment="Center"/>
                            <TextBlock Text="Work | Emg" Foreground="#AAA" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Wed -->
                    <Border x:Name="DayHeader2" Grid.Column="3" Style="{StaticResource DayHeaderNormal}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="DayName2" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="DayDate2" Foreground="#CCC" FontSize="11" HorizontalAlignment="Center"/>
                            <TextBlock Text="Work | Emg" Foreground="#AAA" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Thu -->
                    <Border x:Name="DayHeader3" Grid.Column="4" Style="{StaticResource DayHeaderNormal}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="DayName3" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="DayDate3" Foreground="#CCC" FontSize="11" HorizontalAlignment="Center"/>
                            <TextBlock Text="Work | Emg" Foreground="#AAA" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Fri -->
                    <Border x:Name="DayHeader4" Grid.Column="5" Style="{StaticResource DayHeaderNormal}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="DayName4" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="DayDate4" Foreground="#CCC" FontSize="11" HorizontalAlignment="Center"/>
                            <TextBlock Text="Work | Emg" Foreground="#AAA" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Sat -->
                    <Border x:Name="DayHeader5" Grid.Column="6" Style="{StaticResource DayHeaderNormal}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="DayName5" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="DayDate5" Foreground="#CCC" FontSize="11" HorizontalAlignment="Center"/>
                            <TextBlock Text="Work | Emg" Foreground="#AAA" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Sun -->
                    <Border x:Name="DayHeader6" Grid.Column="7" Style="{StaticResource DayHeaderNormal}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="DayName6" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="DayDate6" Foreground="#CCC" FontSize="11" HorizontalAlignment="Center"/>
                            <TextBlock Text="Work | Emg" Foreground="#AAA" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                </Grid>

                <!-- Doctor rows inserted here by code-behind -->
                <StackPanel x:Name="DoctorRowsPanel"/>

            </StackPanel>
        </ScrollViewer>

        <!-- FOOTER BUTTONS -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,15,0,0">
            <Button Content="Save Rotation"
                    Width="130" Height="32"
                    Margin="0,0,10,0"
                    Click="Save_Click"/>
            <Button Content="Back"
                    Width="80" Height="32"
                    Click="Back_Click"/>
        </StackPanel>

    </Grid>
</Page>