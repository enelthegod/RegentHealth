<Page x:Class="RegentHealth.Views.Admin.TodayAppointmentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Today Appointments">

    <Grid Margin="40" Background="#f0f0f0">

        <StackPanel>

            <!-- Page title -->
            <TextBlock Text="Today's Appointments"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <ListView x:Name="AppointmentsList">

                <!-- Handle double-click on item -->
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <EventSetter Event="MouseDoubleClick" Handler="Appointment_DoubleClick"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <!-- Grouping by doctor -->
                <ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <!-- Display doctor name with prefix -->
                                <TextBlock Text="{Binding Name, StringFormat=Doctor: {0}}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Margin="0,10,0,5"/>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListView.GroupStyle>

                <!-- Template for each appointment -->
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8"
                                Margin="4"
                                Background="White"
                                BorderBrush="#DDD"
                                BorderThickness="1"
                                CornerRadius="6">
                            <StackPanel Orientation="Horizontal">
                                <!-- Appointment time -->
                                <TextBlock Width="60"
                                           Text="{Binding AppointmentDate, StringFormat='{}{0:HH:mm}'}"/>
                                <!-- Patient name -->
                                <TextBlock Width="160"
                                           Text="{Binding PatientFullName}"/>
                                <!-- Appointment status -->
                                <TextBlock Text="{Binding Status}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Back button -->
            <Button Content="Back"
                    Width="120"
                    Height="35"
                    Margin="0,20,0,0"
                    Click="Back_Click"/>

        </StackPanel>
    </Grid>
</Page>