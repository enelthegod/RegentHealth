<Page x:Class="RegentHealth.Views.Admin.DoctorDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Doctor Details">

    <Grid Margin="40" Background="#f0f0f0">

        <StackPanel>

            <!-- Doctor Name -->
            <TextBlock x:Name="DoctorNameText"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <!-- Status -->
            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,20">

                <TextBlock Text="Shift Status:"
                           FontWeight="Bold"/>

                <TextBlock x:Name="ShiftStatusText"
                           Margin="10,0"/>

                <TextBlock Text="Emergency:"
                           FontWeight="Bold"
                           Margin="30,0,0,0"/>

                <TextBlock x:Name="EmergencyStatusText"
                           Margin="10,0"/>

            </StackPanel>


            <!-- Appointments -->
            <TextBlock Text="Appointments"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <ListBox x:Name="AppointmentsList">

                <ListBox.ItemTemplate>
                    <DataTemplate>

                        <Border Background="White"
                                Padding="10"
                                Margin="5"
                                BorderBrush="#DDD"
                                BorderThickness="1"
                                CornerRadius="6">

                            <StackPanel>

                                <TextBlock FontWeight="Bold"
                                           Text="{Binding PatientFullName}"/>

                                <TextBlock Text="{Binding AppointmentDate,
                                          StringFormat='{}{0:dd MMM yyyy HH:mm}'}"/>

                                <TextBlock Text="{Binding Status}"/>

                            </StackPanel>

                        </Border>

                    </DataTemplate>
                </ListBox.ItemTemplate>

            </ListBox>

            <Button Content="Back"
                    Width="120"
                    Height="35"
                    Margin="0,20,0,0"
                    Click="Back_Click"/>

        </StackPanel>
    </Grid>
</Page>
