<Page x:Class="RegentHealth.Views.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Admin Panel">

    <Grid Margin="20" Background="#f0f0f0">

        <StackPanel Width="300">

            <TextBlock Text="Create Doctor"
               FontSize="20"
               FontWeight="Bold"
               Margin="0,0,0,20"/>

            <TextBlock Text="Name"/>
            <TextBox x:Name="NameBox"
             Margin="0,5"/>

            <TextBlock Text="Surname"/>
            <TextBox x:Name="SurnameBox"
             Margin="0,5"/>

            <TextBlock Text="Email"/>
            <TextBox x:Name="EmailBox"
             Margin="0,5"/>

            <TextBlock Text="Password"/>
            <PasswordBox x:Name="PasswordBox"
                 Margin="0,5"/>

            <Button Content="Create Doctor"
            Margin="0,15"
            Click="CreateDoctor_Click"/>

            <TextBlock Text="Today's Doctors"
           FontSize="18"
           Margin="0,30,0,10"/>

            <ListBox x:Name="DoctorsList"
         Height="250">

                <ListBox.ItemTemplate>
                    <DataTemplate>

                        <Grid Margin="5">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <!-- ACTIVE CHECKBOX -->
                            <CheckBox Grid.Column="0"
                            IsChecked="{Binding IsActive}"
                            Checked="DoctorActive_Click"
                            Unchecked="DoctorActive_Click"/>

                            <!-- NAME -->
                            <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           FontSize="16"
                           Text="{Binding FullName}"/>

                            <!-- EMERGENCY -->
                            <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           Cursor="Hand"
                           FontWeight="Bold"
                           Margin="10,0,0,0"
                           MouseDown="Emergency_Click"
                           Text="Emergency">

                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">

                                        <Setter Property="Foreground" Value="Red"/>

                                        <Style.Triggers>

                                            <DataTrigger Binding="{Binding IsEmergencyDoctor}" Value="True">
                                                <Setter Property="Foreground" Value="Green"/>
                                            </DataTrigger>

                                        </Style.Triggers>

                                    </Style>
                                </TextBlock.Style>

                            </TextBlock>

                        </Grid>

                    </DataTemplate>
                </ListBox.ItemTemplate>

            </ListBox>

            <Button Content="Back"
        Width="120"
        Height="35"
        Margin="0,20,0,0"
        HorizontalAlignment="Right"
        Click="Back_Click"/>
            
        </StackPanel>
    </Grid>
</Page>