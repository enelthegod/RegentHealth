<Page x:Class="RegentHealth.Views.Admin.CreateDoctorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="CreateDoctorPage">

    <Grid Background="#f0f0f0">

        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="1"
                    Width="350"
                    HorizontalAlignment="Center">

            <TextBlock Text="Create Doctor"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,0,0,30"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="First Name"/>
            <TextBox x:Name="NameBox"
                     Height="40"
                     FontSize="16"
                     Margin="0,5,0,10"
                     Padding="8"/>

            <TextBlock Text="Last Name"/>
            <TextBox x:Name="SurnameBox"
                     Height="40"
                     FontSize="16"
                     Margin="0,5,0,10"
                     Padding="8"/>

            <TextBlock Text="Email"/>
            <TextBox x:Name="EmailBox"
                     Height="40"
                     FontSize="16"
                     Margin="0,5,0,10"
                     Padding="8"/>

            <TextBlock Text="Password"/>
            <PasswordBox x:Name="PasswordBox"
                         Height="40"
                         FontSize="16"
                         Margin="0,5,0,20"
                         Padding="8"/>

            <Button Content="Create Doctor"
                    Height="45"
                    FontSize="16"
                    Click="Create_Click"/>

            <Button Content="Back"
         Width="120"
         Height="35"
         Margin="0,20,0,0"
         Click="Back_Click"/>

        </StackPanel>

    </Grid>
</Page>
           
