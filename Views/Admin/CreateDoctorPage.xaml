<Page x:Class="RegentHealth.Views.Admin.CreateDoctorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Create Doctor">

    <Border Background="#f0f0f0"
        Padding="30"
        CornerRadius="8"
        BorderBrush="#DDD"
        BorderThickness="1">

        <Grid Margin="40" Background="#f0f0f0">


            <StackPanel Width="300"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <TextBlock Text="Create Doctor"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

                <TextBlock Text="Name"/>
                <TextBox x:Name="NameBox"
                     Margin="0,5,0,10"/>

                <TextBlock Text="Surname"/>
                <TextBox x:Name="SurnameBox"
                     Margin="0,5,0,10"/>

                <TextBlock Text="Email"/>
                <TextBox x:Name="EmailBox"
                     Margin="0,5,0,10"/>

                <TextBlock Text="Password"/>
                <PasswordBox x:Name="PasswordBox"
                         Margin="0,5,0,20"/>

                <Button Content="Create Doctor"
                    Height="35"
                    Click="Create_Click"/>
                
                <Button Content="Back"
                        Width="120"
                        Height="35"
                        Margin="0,20,0,0"
                        Click="Back_Click"/>


            </StackPanel>
        </Grid>
    </Border>
</Page>