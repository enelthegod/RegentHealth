<Page x:Class="RegentHealth.Views.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Admin Panel">

    <Grid Margin="40"  Background="#f0f0f0">

        <StackPanel Width="300">

            <Button Click="Back_Click"
            Width="40"
            Height="40"
            Background="Transparent"
            BorderThickness="0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="10"
            Cursor="Hand">

                <TextBlock Text="←"
                   FontSize="20"
                   FontWeight="Bold"/>
            </Button>

            <TextBlock Text="Admin Dashboard"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0,0,0,30"/>

            <Button Content="Create Doctor"
                Height="40"
                Margin="0,10"
                Click="CreateDoctor_Click"/>

            <Button Content="Today's Rotation"
                Height="40"
                Margin="0,10"
                Click="Rotation_Click"/>

            <Button Content="Doctors List"
                Height="40"
                Margin="0,10"
                Click="Doctors_Click"/>

            <Button Content="Today's Appointments"
                Height="40"
                Margin="0,10"
                Click="Appointments_Click"/>


        </StackPanel>

    </Grid>
</Page>