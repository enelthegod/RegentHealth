<Page x:Class="RegentHealth.Views.Admin.RotationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Weekly Rotation">

    <Grid Margin="40" Background="#f0f0f0">

        <StackPanel>

            <TextBlock Text="Weekly Doctor Rotation"
           FontSize="28"
           FontWeight="Bold"
           Margin="0,0,0,20"/>

            <ListBox x:Name="RotationList"
         Height="350"/>

            <Button Content="Back"
        Width="120"
        Margin="0,20,0,0"
        Click="Back_Click"/>

        </StackPanel>

    </Grid>
</Page>