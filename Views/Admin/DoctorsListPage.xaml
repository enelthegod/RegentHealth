<Page x:Class="RegentHealth.Views.Admin.DoctorsListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Doctors List">

    <Grid Margin="40" Background="#f0f0f0">

        <StackPanel>

            <TextBlock Text="Doctors"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <ListBox x:Name="DoctorsList"
                     MouseDoubleClick="Doctor_Open">

                <ListBox.ItemTemplate>
                    <DataTemplate>

                        <Border Background="White"
                                Padding="12"
                                Margin="5"
                                CornerRadius="6"
                                BorderBrush="#DDD"
                                BorderThickness="1">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Doctor name -->
                                <TextBlock FontSize="16"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Text="{Binding FullName}"/>

                                <!-- Delete button -->
                                <Button Grid.Column="1"
                                        Content="Delete"
                                        Margin="10,0"
                                        Padding="10,4"
                                        Click="DeleteDoctor_Click"/>

                            </Grid>

                        </Border>

                    </DataTemplate>
                </ListBox.ItemTemplate>

            </ListBox>

            <StackPanel Orientation="Horizontal"
                        Margin="0,20,0,0">

                <Button Content="Create Doctor"
                        Width="150"
                        Height="35"
                        Margin="0,0,10,0"
                        Click="CreateDoctor_Click"/>

                <Button Content="Back"
                        Width="100"
                        Height="35"
                        Click="Back_Click"/>

            </StackPanel>
        </StackPanel>
    </Grid>
</Page>